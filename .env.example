# ── Email Alerts ────────────────────────────────────────────
# For Gmail: Use an App Password (not your regular password)
# Go to: Google Account > Security > 2-Step Verification > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_TO=your_email@gmail.com

# ── Claude API (stock analysis) ────────────────────────────
# Get your key at https://console.anthropic.com/settings/keys
# Cost: ~$0.03/day ($0.66/month) with Sonnet 4.6
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Telegram Bot (Intraday Alerts) ────────────────────────
# Create bot via @BotFather, get chat ID via @userinfobot or getUpdates API
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── MeroShare (Portfolio Sync) ─────────────────────────────
# Get your DP ID and Client ID from your broker/CDSC
MEROSHARE_DP=your_dp_id
MEROSHARE_CLIENT_ID=your_client_id
MEROSHARE_USERNAME=your_username
MEROSHARE_PASSWORD=your_password
